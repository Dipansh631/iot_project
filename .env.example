# ============================================================
# Traffic Monitoring System - Environment Variables
# Copy this file to .env and fill in your values
# ============================================================

# Supabase Configuration (optional - system works with SQLite by default)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_KEY=your-service-role-key-here

# JWT Secret for local auth (generate a random 32+ char string)
JWT_SECRET_KEY=change-me-to-a-random-secret-key-minimum-32-chars

# Database Mode: "sqlite" (default/offline) or "supabase"
DB_MODE=sqlite

# App Settings
APP_HOST=127.0.0.1
APP_PORT=8000
DEBUG=true

# Email Alerts (optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
ALERT_FROM_EMAIL=alerts@trafficmonitor.gov.in
